###############################################################################
# PriseClaw local environment template
#
# Copy to `.env` on your Raspberry Pi. Never commit the real `.env`.
###############################################################################

# Telegram bot token from @BotFather. Reuse your private PriseClaw bot here.
TELEGRAM_BOT_TOKEN=replace_with_your_bot_token_from_botfather

# OpenAI key for the PriseClaw OpenCode provider path.
OPENAI_API_KEY=replace_with_your_openai_api_key

# PriseClaw defaults: OpenAI through NanoClaw's OpenCode provider.
NANOCLAW_AGENT_PROVIDER=opencode
OPENCODE_PROVIDER=openai
OPENCODE_MODEL=openai/gpt-5.4-mini
OPENCODE_SMALL_MODEL=openai/gpt-5.4-mini

# Name retained from NanoClaw/OpenCode bridge; for PriseClaw it points to OpenAI.
ANTHROPIC_BASE_URL=https://api.openai.com/v1

# Written by setup. Usually leave blank in the template.
# ONECLI_URL=
