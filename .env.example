# Required: create a bot with BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=

# Required: comma-separated Telegram numeric user IDs allowed to use the bot.
# To discover your ID safely, run once with DISCOVERY_MODE=true, message the bot,
# read the console log, then turn discovery mode off and set ALLOWED_TELEGRAM_USER_IDS.
ALLOWED_TELEGRAM_USER_IDS=
DISCOVERY_MODE=false

# Optional online reasoning API.
# Leave empty to run only the local rule-based parser.
# If set, message text/transcripts can be sent to OpenAI for richer parsing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. Path to a whisper.cpp executable on the Pi.
# Example: /opt/whisper.cpp/build/bin/whisper-cli
WHISPER_CPP_BIN=
WHISPER_MODEL_PATH=
FFMPEG_BIN=ffmpeg

# Optional.
DATA_DIR=./data
BOT_TIMEZONE=Asia/Singapore
DAILY_BRIEFING_TIME=08:00
UPDATE_CHECK_INTERVAL_MINUTES=15
